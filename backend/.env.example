# ── LLM providers (all free, no credit card) ──────────────────────────────
# Tip: any key var accepts a COMMA-SEPARATED LIST → the gateway rotates through
# them and auto-switches when one is rate-limited (429). NOTE: extra Groq keys
# only add quota if they're from SEPARATE accounts (Groq limits are per-org).

# Primary engine. Free key at https://console.groq.com  (starts with gsk_)
GROQ_API_KEY=gsk_your_key_here

# Second pool — fastest free inference (~1,800 tok/s), 1M tokens/day, no card.
# Free key at https://cloud.cerebras.ai  → its own rate-limit pool (great for failover)
CEREBRAS_API_KEY=

# Optional. Get at https://aistudio.google.com/apikey — MUST start with "AIza".
# NOTE: some accounts only issue "AQ.*" keys, which 401 on the REST API; leave
# this blank if that's you — Groq alone is plenty.
GEMINI_API_KEY=

# Optional last-resort fallback (Kimi etc.). https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Supabase (DB + Auth) — Settings → API Keys in the dashboard ────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Server ────────────────────────────────────────────────────────────────
PORT=3024
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MAX_CONCURRENT_AI_CALLS=8
AI_CALL_TIMEOUT_MS=45000
